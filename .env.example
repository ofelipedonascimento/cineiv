# ══════════════════════════════════════
# CINE IV STUDIO — Configuração
# ══════════════════════════════════════
# Copie este arquivo para .env e preencha:
#   cp .env.example .env

# ── Servidor ──
PORT=3000
SESSION_SECRET=cineiv-studio-2025-sua-chave-secreta-aqui

# ── Asaas (Financeiro) ──
# Gere sua API Key em: Asaas → Minha Conta → Integração → Gerar API Key
# Produção: $aact_prod_...
# Sandbox:  $aact_hmlg_...
ASAAS_API_KEY=
ASAAS_SANDBOX=false

# ── WhatsApp (Evolution API) ──
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=cineiv-evolution-key
EVOLUTION_INSTANCE=cineiv

# ── Acesso Externo (DDNS) ──
# Configure no No-IP: cineiv.ddns.net
# Porta liberada no roteador Claro: 3000
EXTERNAL_URL=http://cineiv.ddns.net:3000
